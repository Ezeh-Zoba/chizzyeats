rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null && request.auth.token.role == "admin";
    }

    match /recipes/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
